      "source_layer_detail": "utilities.icons.ftl (snapshot from Squiz platform)",
      "modifiability": {
        "who_controls": "Squiz platform (snapshot in docs/)",
        "modification_implication": "local edit would diverge from Squiz canonical; Squiz updates would not propagate unless re-pulled"
      },
      "structural_role": "SVG sprite defining 93 symbols inside a single `<svg><defs>...</defs></svg>` block. Included from partial.ftl L93 wrapped in `<div style='display:none'>` so symbols are referenceable via `<use href='#id'>` from anywhere in the partial response but render no visible chrome themselves.",
      "see": "sprite_symbol_map (top-level key of this document) for the full defined symbol list, the referenced-in-partial-response cross-reference, and the 83-symbol unreferenced list.",
