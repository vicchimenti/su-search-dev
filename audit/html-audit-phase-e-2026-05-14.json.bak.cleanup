  "entries": [
    {
      "id": "partial-ftl-master-composition",
      "source_layer": "FUNNELBACK_PARTIAL",
      "source_layer_detail": "partial.ftl",
      "writer": {
        "file": "partial.ftl",
        "line_range": "1-250"
      },
      "modifiability": {
        "who_controls": "Vic-controlled FTL",
        "modification_implication": "Read-and-modify-cautiously per Phase C C11. Modifications are rebuild-development-phase actions."
      },
      "structural_role": "Master composition template for the Funnelback partial response. Defines DOM scaffold (stencils__main higher-education > grid-container > funnelback-search), invokes hero_banner.SearchForm, tabs.Tabs, the facets sidebar with tab-conditional CTA block and curator-left slot, then the main body column (search_tools, query_blending, spelling_suggestions, facets_breadcrumbs, AfterSearchOnly{curator-top, no_results, result_list, curator-bottom}, pagination, contextual_navigation). Ends with a script tag loading the Squiz stencils main.js bundle.",
      "consumed_attributes_and_state": {
        "FUNNELBACK_BACKEND_STATE": [
          "response.customData.stencils.tabs.selected (L137; drives the tab-conditional CTA)",
          "question.collection.id (L250; in script src URL)",
          "question.profile (L250; in script src URL)",
          "httpHost from httpRequest.getHeader('host') (L82, L250)"
        ],
        "FUNNELBACK_PROFILE_CONFIG": [
          "stencils.tabs.facets.${(response.customData.stencils.tabs.selected)} (L182; per-tab facet list)",
          "stencils.faceted_navigation.max_displayed_categories (L187; show-more threshold)"
        ]
      },
      "emitted_dom_anchor_ids": [
        "funnelbach-search-facets (L121 \u2014 TYPO 'funnelbach' not 'funnelback')",
        "funnelbach-search-body (L211 \u2014 same typo)"
      ],
      "child_invocations_first_layer": [
        "hero_banner.SearchForm (L107)",
        "tabs.Tabs (L108)",
        "facets.HasFacets/Facets (L184-189)",
        "curator.HasCuratorOrBestBet/Curator (L192-194, L222-224, L229-231 \u2014 three positions: left/top/bottom)",
        "search_tools.SearchTools (L214)",
        "query_blending.QueryBlending (L216)",
        "spelling_suggestions.SpellingSuggestions (L217)",
